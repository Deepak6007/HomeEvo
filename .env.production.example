# =========================================================================
# HomeEvo — Production Environment Configurations Template
# =========================================================================

# Database Setup (Postgres Production Instance)
DATABASE_URL="postgresql://<prod_username>:<prod_password>@<prod_host>:<prod_port>/<prod_db_name>?sslmode=require"

# Cache Store Setup (Redis Production Cluster)
REDIS_URL="rediss://:<prod_redis_password>@<prod_redis_host>:<prod_redis_port>"

# Public Next.js Endpoints (Client Accessible)
# IMPORTANT: Never include trailing slashes.
# In production, set to your production frontend domain (re-routes /api via Next.js proxy)
NEXT_PUBLIC_API_URL="https://api.homeevo.in/api/v1"
NEXT_PUBLIC_RAZORPAY_KEY="rzp_live_ProductionKeyIDHere"
NEXT_PUBLIC_WS_URL="wss://realtime.homeevo.in"

# Security & Sessions Configuration
# Generate a cryptographically strong random secret (e.g. `openssl rand -base64 32`)
JWT_SECRET="generate_a_cryptographically_secure_random_base64_secret_key"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="30d"

# Claude AI Blueprint Generator API Config
ANTHROPIC_API_KEY="sk-ant-apixx-your_production_anthropic_key"

# Cloudinary File Storage Credentials
CLOUDINARY_CLOUD_NAME="homeevo_prod_cloudinary_cloud"
CLOUDINARY_API_KEY="cloudinary_production_api_key"
CLOUDINARY_API_SECRET="cloudinary_production_api_secret"

# Razorpay PaymentsEscrow Escrow Ledger Gateways
RAZORPAY_KEY_ID="rzp_live_ProductionKeyIDHere"
RAZORPAY_KEY_SECRET="razorpay_production_api_secret"
RAZORPAY_WEBHOOK_SECRET="razorpay_production_webhook_secret_dedup"

# Build Node Environment Mode
NODE_ENV="production"

# Hugging Face Inference API Configuration
HF_TOKEN="hf_your_production_huggingface_token"
HF_MODEL="Qwen/Qwen2.5-72B-Instruct"
HF_MODEL_FALLBACK="mistralai/Mistral-7B-Instruct-v0.3"
