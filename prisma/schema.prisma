// ─── DATABASE CONFIG ─────────────────────────────────
// LOCAL DEV: postgresql://homeevo:homeevo_dev_password@localhost:5432/homeevo_db
// NEON PROD: postgresql://user:pass@host.neon.tech/neondb?sslmode=require
// To switch: update DATABASE_URL in .env.local
// Run: npx prisma migrate deploy (not dev) in production

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── ENUMS ────────────────────────────────────────────

enum UserRole {
  CLIENT
  VENDOR
  ADMIN
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  PENDING_VERIFICATION
  DELETED
}

enum ProjectStatus {
  DRAFT
  PENDING_BIDS
  ACTIVE
  ON_HOLD
  COMPLETED
  DISPUTED
  CANCELLED
}

enum MilestoneStatus {
  UPCOMING
  IN_PROGRESS
  PENDING_APPROVAL
  RELEASED
  DISPUTED
}

enum BidStatus {
  PENDING
  ACCEPTED
  REJECTED
  WITHDRAWN
  EXPIRED
}

enum PaymentType {
  ESCROW_DEPOSIT
  MILESTONE_RELEASE
  MATERIALS_ORDER
  REFUND
  PLATFORM_FEE
}

enum PaymentStatus {
  INITIATED
  CAPTURED
  RELEASED
  REFUNDED
  FAILED
}

enum OrderStatus {
  CART
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum ComplaintPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum ComplaintStatus {
  OPEN
  IN_REVIEW
  RESOLVED
  ESCALATED
  CLOSED
}

enum MessageType {
  TEXT
  FILE
  IMAGE
  SYSTEM
}

enum SenderRole {
  CLIENT
  VENDOR
  ADMIN
}

// ─── USERS ────────────────────────────────────────────

model User {
  id           String     @id @default(uuid())
  email        String     @unique
  passwordHash String     @map("password_hash")
  name         String
  phone        String?
  avatarUrl    String?    @map("avatar_url")
  role         UserRole   @default(CLIENT)
  status       UserStatus @default(ACTIVE)
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")
  lastLoginAt  DateTime?  @map("last_login_at")

  // Relations
  vendorProfile    VendorProfile?
  clientProjects   Project[]       @relation("ClientProjects")
  vendorProjects   Project[]       @relation("VendorProjects")
  bids             Bid[]
  sentMessages     Message[]       @relation("SentMessages")
  notifications    Notification[]
  reviewsWritten   Review[]        @relation("ReviewsWritten")
  reviewsReceived  Review[]        @relation("ReviewsReceived")
  orders           Order[]
  sitePhotos       SitePhoto[]
  complaintsFiledBy Complaint[]    @relation("ComplaintsFiledBy")
  complaintsAgainst Complaint[]    @relation("ComplaintsAgainst")
  milestoneApprovals Milestone[]   @relation("MilestoneApprovals")
  blueprintSaves    BlueprintSave[]

  @@index([role])
  @@index([status])
  @@map("users")
}

// ─── BLUEPRINT SAVES ──────────────────────────────────

model BlueprintSave {
  id            String   @id @default(uuid())
  userId        String   @map("user_id")
  formData      Json     @map("form_data")
  blueprintData Json     @map("blueprint_data")
  createdAt     DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("blueprint_saves")
}

// ─── VENDOR PROFILES ──────────────────────────────────

model VendorProfile {
  id                String   @id @default(uuid())
  userId            String   @unique @map("user_id")
  businessName      String   @map("business_name")
  category          String
  description       String?
  gstin             String?
  aadhaarHash       String?  @map("aadhaar_hash")
  yearsExperience   Int      @default(0) @map("years_experience")
  avgRating         Float    @default(0) @map("avg_rating")
  reviewCount       Int      @default(0) @map("review_count")
  isVerified        Boolean  @default(false) @map("is_verified")
  isAvailable       Boolean  @default(true) @map("is_available")
  profileCompletion Int      @default(0) @map("profile_completion")
  serviceAreas      String[] @map("service_areas")
  verifiedAt        DateTime? @map("verified_at")
  verifiedByAdminId String?   @map("verified_by_admin_id")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  portfolioPhotos PortfolioPhoto[]
  reviews        Review[]

  @@index([category])
  @@index([isVerified])
  @@index([isAvailable])
  @@index([verifiedByAdminId])
  @@map("vendor_profiles")
}

// ─── PROJECTS ─────────────────────────────────────────

model Project {
  id          String        @id @default(uuid())
  clientId    String        @map("client_id")
  vendorId    String?       @map("vendor_id")
  title       String
  category    String
  description String?
  location    String
  budget      Decimal       @db.Decimal(12, 2)
  status      ProjectStatus @default(DRAFT)
  startDate   DateTime?     @map("start_date")
  endDate     DateTime?     @map("end_date")
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  client     User        @relation("ClientProjects", fields: [clientId], references: [id])
  vendor     User?       @relation("VendorProjects", fields: [vendorId], references: [id])
  milestones Milestone[]
  bids       Bid[]
  sitePhotos SitePhoto[]
  messages   Message[]
  reviews    Review[]
  complaints Complaint[]
  payments   Payment[]

  @@index([clientId])
  @@index([vendorId])
  @@index([status])
  @@map("projects")
}

// ─── MILESTONES ───────────────────────────────────────

model Milestone {
  id           String          @id @default(uuid())
  projectId    String          @map("project_id")
  title        String
  deliverable  String?
  amount       Decimal         @db.Decimal(12, 2)
  status       MilestoneStatus @default(UPCOMING)
  orderIndex   Int             @map("order_index")
  dueDate      DateTime?       @map("due_date")
  approvedAt   DateTime?       @map("approved_at")
  approvedById String?         @map("approved_by_id")
  createdAt    DateTime        @default(now()) @map("created_at")
  updatedAt    DateTime        @updatedAt @map("updated_at")

  project    Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  approvedBy User?     @relation("MilestoneApprovals", fields: [approvedById], references: [id])
  payments   Payment[]

  @@index([projectId])
  @@index([status])
  @@map("milestones")
}

// ─── BIDS ─────────────────────────────────────────────

model Bid {
  id            String    @id @default(uuid())
  projectId     String    @map("project_id")
  vendorId      String    @map("vendor_id")
  totalAmount   Decimal   @db.Decimal(12, 2) @map("total_amount")
  timelineWeeks Int       @map("timeline_weeks")
  message       String?
  status        BidStatus @default(PENDING)
  milestones    Json      // Array of { title, amount, deliverable, timelineWeeks }
  submittedAt   DateTime  @default(now()) @map("submitted_at")
  respondedAt   DateTime? @map("responded_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  vendor  User    @relation(fields: [vendorId], references: [id])

  @@index([projectId])
  @@index([vendorId])
  @@index([status])
  @@map("bids")
}

// ─── PAYMENTS ─────────────────────────────────────────

model Payment {
  id                  String        @id @default(uuid())
  projectId           String?       @map("project_id")
  milestoneId         String?       @map("milestone_id")
  orderId             String?       @map("order_id")
  payerId             String        @map("payer_id")
  payeeId             String?       @map("payee_id")
  amount              Decimal       @db.Decimal(12, 2)
  type                PaymentType
  status              PaymentStatus @default(INITIATED)
  razorpayOrderId     String?       @unique @map("razorpay_order_id")
  razorpayPaymentId   String?       @map("razorpay_payment_id")
  razorpaySignature   String?       @map("razorpay_signature")
  notes               String?
  createdAt           DateTime      @default(now()) @map("created_at")
  updatedAt           DateTime      @updatedAt @map("updated_at")

  project   Project?    @relation(fields: [projectId], references: [id])
  milestone Milestone?  @relation(fields: [milestoneId], references: [id])
  order     Order?      @relation(fields: [orderId], references: [id])

  @@index([projectId])
  @@index([milestoneId])
  @@index([orderId])
  @@index([payerId])
  @@index([payeeId])
  @@index([status])
  @@map("payments")
}

// ─── WEBHOOK EVENTS (idempotency table) ───────────────

model WebhookEvent {
  id               String    @id @default(uuid())
  // razorpayWebhookId is the deduplication key
  // ALWAYS check this before processing any payment event
  razorpayWebhookId String   @unique @map("razorpay_webhook_id")
  eventType        String    @map("event_type")
  payload          Json
  processed        Boolean   @default(false)
  receivedAt       DateTime  @default(now()) @map("received_at")
  processedAt      DateTime? @map("processed_at")

  @@index([processed])
  @@map("webhook_events")
}

// ─── PRODUCTS ─────────────────────────────────────────

model Product {
  id          String      @id @default(uuid())
  name        String
  category    String
  description String?
  price       Decimal     @db.Decimal(10, 2)
  unit        String      // "bag", "kg", "piece", "sq_ft"
  stock       Int         @default(0)
  images      String[]
  isActive    Boolean     @default(true) @map("is_active")
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  orderItems OrderItem[]

  @@index([category])
  @@index([isActive])
  @@map("products")
}

// ─── ORDERS ───────────────────────────────────────────

model Order {
  id              String      @id @default(uuid())
  clientId        String      @map("client_id")
  subtotal        Decimal     @db.Decimal(12, 2)
  deliveryFee     Decimal     @db.Decimal(8, 2) @map("delivery_fee")
  total           Decimal     @db.Decimal(12, 2)
  status          OrderStatus @default(CART)
  deliveryAddress Json        @map("delivery_address")
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")

  client    User        @relation(fields: [clientId], references: [id])
  items     OrderItem[]
  payments  Payment[]

  @@index([clientId])
  @@index([status])
  @@map("orders")
}

model OrderItem {
  id         String  @id @default(uuid())
  orderId    String  @map("order_id")
  productId  String  @map("product_id")
  quantity   Int
  unitPrice  Decimal @db.Decimal(10, 2) @map("unit_price")
  totalPrice Decimal @db.Decimal(10, 2) @map("total_price")

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@index([productId])
  @@map("order_items")
}

// ─── REVIEWS ──────────────────────────────────────────

model Review {
  id           String    @id @default(uuid())
  projectId    String    @map("project_id")
  reviewerId   String    @map("reviewer_id")
  vendorId     String    @map("vendor_id")
  vendorProfileId String @map("vendor_profile_id")
  rating       Int       // 1–5, validated in application layer
  comment      String?
  vendorReply  String?   @map("vendor_reply")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  project       Project       @relation(fields: [projectId], references: [id])
  reviewer      User          @relation("ReviewsWritten", fields: [reviewerId], references: [id])
  vendor        User          @relation("ReviewsReceived", fields: [vendorId], references: [id])
  vendorProfile VendorProfile @relation(fields: [vendorProfileId], references: [id])

  @@index([vendorId])
  @@index([projectId])
  @@index([reviewerId])
  @@index([vendorProfileId])
  @@map("reviews")
}

// ─── MESSAGES ─────────────────────────────────────────

model Message {
  id             String      @id @default(uuid())
  conversationId String      @map("conversation_id")
  senderId       String      @map("sender_id")
  projectId      String?     @map("project_id")
  senderRole     SenderRole  @map("sender_role")
  content        String?
  type           MessageType @default(TEXT)
  fileUrl        String?     @map("file_url")
  isRead         Boolean     @default(false) @map("is_read")
  createdAt      DateTime    @default(now()) @map("created_at")

  sender  User     @relation("SentMessages", fields: [senderId], references: [id])
  project Project? @relation(fields: [projectId], references: [id])

  @@index([conversationId])
  @@index([senderId])
  @@index([projectId])
  @@map("messages")
}

// ─── NOTIFICATIONS ────────────────────────────────────

model Notification {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  type      String   // NEW_LEAD, MILESTONE_APPROVED, PAYMENT_RELEASED, BID_ACCEPTED, etc.
  title     String
  message   String
  metadata  Json?    // { projectId, milestoneId, bidId, etc. }
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@map("notifications")
}

// ─── SITE PHOTOS ──────────────────────────────────────

model SitePhoto {
  id             String   @id @default(uuid())
  projectId      String   @map("project_id")
  uploadedById   String   @map("uploaded_by_id")
  cloudinaryUrl  String   @map("cloudinary_url")
  cloudinaryId   String   @map("cloudinary_id")
  caption        String?
  createdAt      DateTime @default(now()) @map("created_at")

  project    Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  uploadedBy User    @relation(fields: [uploadedById], references: [id])

  @@index([projectId])
  @@index([uploadedById])
  @@map("site_photos")
}

// ─── PORTFOLIO PHOTOS ────────────────────────────────

model PortfolioPhoto {
  id              String   @id @default(uuid())
  vendorProfileId String   @map("vendor_profile_id")
  cloudinaryUrl   String   @map("cloudinary_url")
  cloudinaryId    String   @map("cloudinary_id")
  caption         String?
  displayOrder    Int      @default(0) @map("display_order")
  createdAt       DateTime @default(now()) @map("created_at")

  vendorProfile VendorProfile @relation(fields: [vendorProfileId], references: [id], onDelete: Cascade)

  @@index([vendorProfileId])
  @@map("portfolio_photos")
}

// ─── COMPLAINTS ───────────────────────────────────────

model Complaint {
  id           String            @id @default(uuid())
  projectId    String            @map("project_id")
  filedById    String            @map("filed_by_id")
  againstUserId String           @map("against_user_id")
  description  String
  priority     ComplaintPriority @default(MEDIUM)
  status       ComplaintStatus   @default(OPEN)
  adminNotes   String?           @map("admin_notes")
  createdAt    DateTime          @default(now()) @map("created_at")
  resolvedAt   DateTime?         @map("resolved_at")
  updatedAt    DateTime          @updatedAt @map("updated_at")

  project     Project @relation(fields: [projectId], references: [id])
  filedBy     User    @relation("ComplaintsFiledBy", fields: [filedById], references: [id])
  againstUser User    @relation("ComplaintsAgainst", fields: [againstUserId], references: [id])

  @@index([status])
  @@index([priority])
  @@index([projectId])
  @@index([filedById])
  @@index([againstUserId])
  @@map("complaints")
}
